require-infra $SYSTEM_REPO

exec $GC_BIN api repos/$SYSTEM_REPO
json-ok stdout

exec $GC_BIN release list -R $SYSTEM_REPO --json
json-ok stdout

exec $GC_BIN release delete v0.0.1-test -R $SYSTEM_REPO --dry-run

exec $GC_BIN repo delete $SYSTEM_REPO --dry-run

exec $GC_BIN issue create -R $SYSTEM_REPO --title 'System dry-run' --body 'dry-run' --dry-run

exec $GC_BIN label delete system-test-nonexistent -R $SYSTEM_REPO --dry-run
