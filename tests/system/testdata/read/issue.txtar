require-infra $SYSTEM_REPO

exec $GC_BIN issue list -R $SYSTEM_REPO --limit 1

exec $GC_BIN issue list -R $SYSTEM_REPO --limit 1 --json
json-ok stdout
json-assert stdout . array
json-assert stdout [0].number present
json-assert stdout [0].title string
json-assert stdout [0].state nonempty-string
json-assert stdout [0].html_url string
stdout2env ISSUE_NUMBER '"number":[ ]*"?([0-9]+)"?'

exec $GC_BIN issue view $ISSUE_NUMBER -R $SYSTEM_REPO

exec $GC_BIN issue view $ISSUE_NUMBER -R $SYSTEM_REPO --json
json-ok stdout
json-assert stdout . object
json-assert stdout number present
json-assert stdout title string
json-assert stdout state nonempty-string
