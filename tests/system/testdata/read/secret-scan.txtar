require-infra $SYSTEM_REPO

# Secret scanning: inline --body/--comment/--description/--notes flags
# must reject content containing the current GC_TOKEN value.
# Uses a fake token so no real credential is involved and no content
# is actually submitted (the scan rejects before any API call).

env GC_TOKEN=test-secret-token-xyz123-not-real
env GITCODE_TOKEN=

# 1. issue comment --body
! exec $GC_BIN issue comment 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 2. issue comment edit --body
! exec $GC_BIN issue comment edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 3. issue edit --body
! exec $GC_BIN issue edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 4. pr comment --body
! exec $GC_BIN pr comment 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 5. pr comment edit --body
! exec $GC_BIN pr comment edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 6. pr edit --body (scan before EditPR API call)
! exec $GC_BIN pr edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 7. pr review --comment (scan before any API call)
! exec $GC_BIN pr review 1 -R $SYSTEM_REPO --comment 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 8. milestone edit --description (scan before HTTP client creation)
! exec $GC_BIN milestone edit 1 -R $SYSTEM_REPO --description 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 9. release create --notes (scan before HTTP client creation)
! exec $GC_BIN release create test-secret-scan-tag -R $SYSTEM_REPO --notes 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 10. release edit --notes (scan before GetRelease API call)
! exec $GC_BIN release edit test-secret-scan-tag -R $SYSTEM_REPO --notes 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# Negative control: non-token content must NOT be rejected by the scan.
# (This will fail at the API call with 401, not at the scan.)
! exec $GC_BIN issue comment 1 -R $SYSTEM_REPO --body 'harmless content without token'
stderr 'HTTP 401'
