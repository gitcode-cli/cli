require-infra $SYSTEM_REPO

# Secret scanning: inline --body/--comment/--description/--notes flags
# must reject content containing the current GC_TOKEN value.
# Uses a fake token so no real credential is involved and no content
# is actually submitted (the scan rejects before any API call).

env GC_TOKEN=test-secret-token-xyz123-not-real
env GITCODE_TOKEN=

# 1. issue comment --body
! exec $GC_BIN issue comment 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 2. issue comment edit --body
! exec $GC_BIN issue comment edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 3. issue edit --body
! exec $GC_BIN issue edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 4. pr comment --body
! exec $GC_BIN pr comment 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 5. pr comment edit --body
! exec $GC_BIN pr comment edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 6. pr edit --body (scan before EditPR API call)
! exec $GC_BIN pr edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 7. pr review --comment (scan before any API call)
! exec $GC_BIN pr review 1 -R $SYSTEM_REPO --comment 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 8. milestone edit --description (scan before HTTP client creation)
! exec $GC_BIN milestone edit 1 -R $SYSTEM_REPO --description 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 9. release create --notes (scan before HTTP client creation)
! exec $GC_BIN release create test-secret-scan-tag -R $SYSTEM_REPO --notes 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 10. release edit --notes (scan before GetRelease API call)
! exec $GC_BIN release edit test-secret-scan-tag -R $SYSTEM_REPO --notes 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 11. issue close --comment (#426)
! exec $GC_BIN issue close 1 -R $SYSTEM_REPO --comment 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 12. issue reopen --comment (#426)
! exec $GC_BIN issue reopen 1 -R $SYSTEM_REPO --comment 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 13. pr close --comment (#426)
! exec $GC_BIN pr close 1 -R $SYSTEM_REPO --comment 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 14. pr reopen --comment (#426)
! exec $GC_BIN pr reopen 1 -R $SYSTEM_REPO --comment 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 15. pr reply --body (#426, requires --discussion)
! exec $GC_BIN pr reply 1 -R $SYSTEM_REPO --discussion abc123 --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 16. commit comments create --body (#426)
! exec $GC_BIN commit comments create abc123 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 17. commit comments edit --body (#426)
! exec $GC_BIN commit comments edit 1 -R $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 18. milestone create --description (#426)
! exec $GC_BIN milestone create 'test-ms' -R $SYSTEM_REPO --description 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 19. label create --description (#426)
! exec $GC_BIN label create 'test-label' -R $SYSTEM_REPO --description 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 20. repo create --description (#426)
! exec $GC_BIN repo create 'test-secret-scan-repo' --description 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 21. repo sync --body (#426, scan before RootDir)
! exec $GC_BIN repo sync --target-repo $SYSTEM_REPO --source-dir src --target-dir dst --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# 22. pr sync --body (#426, scan before ParsePRRef; use URL format to avoid # comment)
! exec $GC_BIN pr sync --source-pr https://gitcode.com/$SYSTEM_REPO/pulls/1 --target-repo $SYSTEM_REPO --body 'leaked: test-secret-token-xyz123-not-real'
stderr 'secret'

# Negative control: non-token content must NOT be rejected by the scan.
# (This will fail at the API call with 401, not at the scan.)
! exec $GC_BIN issue comment 1 -R $SYSTEM_REPO --body 'harmless content without token'
stderr 'HTTP 401'
